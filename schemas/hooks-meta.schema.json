{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hooks-meta.schema.json",
  "title": "Hook Event Bindings",
  "description": "Maps hook names to the Claude Code events they bind to.",
  "type": "object",
  "additionalProperties": {
    "$ref": "#/$defs/hook"
  },
  "$defs": {
    "hook": {
      "type": "object",
      "required": ["description", "events"],
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "description": "Human-readable hook description."
        },
        "events": {
          "type": "object",
          "description": "Event name → binding config.",
          "additionalProperties": {
            "$ref": "#/$defs/event_binding"
          },
          "propertyNames": {
            "enum": [
              "PreToolUse",
              "PostToolUse",
              "SubagentStop",
              "Stop",
              "Notification"
            ]
          }
        }
      }
    },
    "event_binding": {
      "type": "object",
      "required": ["timeout"],
      "additionalProperties": false,
      "properties": {
        "matcher": {
          "type": "string",
          "description": "Tool name regex to match (e.g. 'Bash', 'Write|Edit')."
        },
        "timeout": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300,
          "description": "Max seconds the hook may run before being killed."
        }
      }
    }
  }
}
